{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
<div class="bg-wrap">
  <section class="bg-related">
    <div class="bg-related__inner">
      {%- if section.settings.kicker != blank -%}<div class="bg-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      <h2 class="bg-h2">{{ section.settings.heading }}</h2>

      {%- assign coll = section.settings.collection -%}
      {%- if coll == blank and product != blank -%}{%- assign coll = product.collections.first -%}{%- endif -%}
      {%- assign tags = section.settings.tags | split: ',' -%}
      <div class="bg-related__grid">
        {%- if coll != blank -%}
          {%- assign shown = 0 -%}
          {%- for p in coll.products -%}
            {%- if product != blank and p.id == product.id -%}{%- continue -%}{%- endif -%}
            {%- if shown >= section.settings.count -%}{%- break -%}{%- endif -%}
            <a class="bg-rcard" href="{{ p.url }}">
              <div class="bg-rcard__media">
                {%- assign t = tags[shown] | default: 'Fresh Drop' -%}
                <span class="bg-tag">{{ t | strip }}</span>
                {%- if p.featured_image -%}
                  <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title | escape }}" loading="lazy">
                {%- else -%}
                  <span class="bg-slot">&#9634; {{ p.title }}</span>
                {%- endif -%}
              </div>
              <div class="bg-rcard__body">
                <h3 class="bg-rcard__title">{{ p.title }}</h3>
                <span class="bg-rcard__price">{{ p.price | money_without_trailing_zeros }}</span>
              </div>
            </a>
            {%- assign shown = shown | plus: 1 -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..section.settings.count) -%}
            <div class="bg-rcard">
              <div class="bg-rcard__media"><span class="bg-tag">Fresh Drop</span><span class="bg-slot">&#9634; Product slot</span></div>
              <div class="bg-rcard__body"><h3 class="bg-rcard__title">Product name</h3><span class="bg-rcard__price">$34</span></div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>
</div>
{% schema %}
{
  "name": "BG Related products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "// Pairs well with" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "More from the garage" },
    { "type": "collection", "id": "collection", "label": "Collection (blank = product's own collection)" },
    { "type": "range", "id": "count", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "text", "id": "tags", "label": "Card labels (comma separated)", "default": "Fresh Drop,Certified Pick,Fresh Drop,New" }
  ],
  "presets": [ { "name": "BG Related products" } ]
}
{% endschema %}
