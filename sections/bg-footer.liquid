{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
<div class="bg-wrap">
  <footer class="bg-footer">
    <div class="bg-footer__inner">
      <div class="bg-footer__cols">
        <div>
          <div class="bg-footer__brand">
            {%- if section.settings.logo != blank -%}
              <img src="{{ section.settings.logo | image_url: width: 104 }}" alt="{{ shop.name }}">
            {%- endif -%}
            <b>{{ section.settings.logo_line1 }}<br><i>{{ section.settings.logo_line2 }}</i></b>
          </div>
          <p>{{ section.settings.blurb }}</p>
        </div>

        {%- for block in section.blocks -%}
          {%- if block.type == 'menu' -%}
            <div {{ block.shopify_attributes }}>
              <h4>{{ block.settings.heading }}</h4>
              <ul>
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <div>
          <h4>{{ section.settings.news_heading }}</h4>
          <p style="margin-bottom:14px;">{{ section.settings.news_text }}</p>
          {%- form 'customer', id: 'bg-news-' | append: section.id, class: 'bg-news' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.news_placeholder }}" required>
            <button type="submit">{{ section.settings.news_button }}</button>
          {%- endform -%}
          <div class="bg-news__msg" data-news-msg hidden role="status" aria-live="polite"></div>
        </div>
      </div>

      <div class="bg-footer__bar">
        <span>{{ section.settings.copyright }}</span>
        <div class="bg-footer__links">
          {%- for link in section.settings.policy_menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </footer>
</div>

<script>
(function(){
  var form=document.getElementById('bg-news-{{ section.id }}');
  if(!form) return;
  var msg=form.parentNode.querySelector('[data-news-msg]');
  var btn=form.querySelector('button[type=submit]');
  var btnText=btn.textContent;
  var okMsg={{ section.settings.news_success | json }};
  var errMsg={{ section.settings.news_error | json }};
  var doneMsg={{ section.settings.news_done | json }};
  var storeKey='bg-news-subscribed';
  function collapse(text){
    show(text, true);
    form.hidden=true;
  }
  if(localStorage.getItem(storeKey)==='1'){ collapse(doneMsg); }
  function show(text, ok){
    msg.textContent=text;
    msg.classList.toggle('is-ok', ok);
    msg.classList.toggle('is-err', !ok);
    msg.hidden=false;
  }
  form.addEventListener('submit',function(e){
    e.preventDefault();
    msg.hidden=true;
    btn.disabled=true; btn.textContent='…';
    fetch(form.action,{ method:'POST', body:new FormData(form), headers:{'Accept':'application/json'} })
      .then(function(r){ return r.json().catch(function(){ return {}; }).then(function(d){ return {status:r.status, data:d}; }); })
      .then(function(res){
        var errs=res.data && res.data.errors;
        if(res.status>=200 && res.status<300 && !errs){
          form.reset();
          try{ localStorage.setItem(storeKey,'1'); }catch(e){}
          collapse(doneMsg);
        } else {
          var t=errMsg;
          if(errs){ if(errs.email){ t=(Array.isArray(errs.email)?errs.email[0]:errs.email); } else if(typeof errs==='string'){ t=errs; } }
          show(t, false);
        }
      })
      .catch(function(){ show(errMsg, false); })
      .then(function(){ btn.disabled=false; btn.textContent=btnText; });
  });
})();
</script>

{% schema %}
{
  "name": "BG Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (badge)" },
    { "type": "text", "id": "logo_line1", "label": "Logo line 1", "default": "BITE" },
    { "type": "text", "id": "logo_line2", "label": "Logo line 2", "default": "GARAGE" },
    { "type": "textarea", "id": "blurb", "label": "Brand blurb", "default": "Certified merch for certified bite mechanics. Printed to order, shipped worldwide." },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "news_heading", "label": "Heading", "default": "Join the crew" },
    { "type": "text", "id": "news_text", "label": "Text", "default": "Get first dibs on every drop straight from the workshop." },
    { "type": "text", "id": "news_placeholder", "label": "Input placeholder", "default": "you@garage.com" },
    { "type": "text", "id": "news_button", "label": "Button label", "default": "Join" },
    { "type": "text", "id": "news_success", "label": "Success message", "default": "You're in — welcome to the crew." },
    { "type": "text", "id": "news_done", "label": "Already-subscribed message (replaces form)", "default": "✓ You're subscribed — welcome to the crew." },
    { "type": "text", "id": "news_error", "label": "Error message", "default": "Something jammed. Check your email and try again." },
    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2026 Bite Garage · Fulfilled by Gelato" },
    { "type": "link_list", "id": "policy_menu", "label": "Policy menu" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4,
  "enabled_on": { "groups": ["footer"] }
}
{% endschema %}
