{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
<div class="bg-wrap">
  <section class="bg-section" id="shop">
    <div class="bg-sechead">
      <div>
        <div class="bg-kicker">{{ section.settings.kicker }}</div>
        <h2 class="bg-h2">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.view_all_link != blank -%}
        <a class="bg-viewall" href="{{ section.settings.view_all_link }}">{{ section.settings.view_all_label }} &rarr;</a>
      {%- endif -%}
    </div>
    <div class="bg-grid">
      {%- assign tags = section.settings.tags | split: ',' -%}
      {%- for product in section.settings.collection.products limit: section.settings.count -%}
        <a class="bg-card" href="{{ product.url }}">
          <div class="bg-card__media">
            {%- assign t = tags[forloop.index0] | default: 'Fresh Drop' -%}
            <span class="bg-tag">{{ t | strip }}</span>
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title }}" loading="lazy">
            {%- else -%}
              <span class="bg-slot">&#9634; {{ product.title }}</span>
            {%- endif -%}
          </div>
          <div class="bg-card__body">
            <div class="bg-card__cat">{{ product.type | default: product.vendor }}</div>
            <h3 class="bg-card__title">{{ product.title }}</h3>
            <div class="bg-card__row">
              <span class="bg-price">{{ product.price | money_without_trailing_zeros }}</span>
              <span class="bg-view">View &rarr;</span>
            </div>
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..section.settings.count) -%}
          <div class="bg-card">
            <div class="bg-card__media"><span class="bg-tag">Fresh Drop</span><span class="bg-slot">&#9634; Product slot</span></div>
            <div class="bg-card__body">
              <div class="bg-card__cat">Category</div>
              <h3 class="bg-card__title">Product name</h3>
              <div class="bg-card__row"><span class="bg-price">$34</span><span class="bg-view">View &rarr;</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </section>
</div>
{% schema %}
{
  "name": "BG Featured products",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "// Workshop inventory" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Merch" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "count", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "text", "id": "tags", "label": "Card labels (comma separated, per product)", "default": "Fresh Drop,Certified Pick,Mechanic Approved,Fresh Drop,New,Certified Pick,Mechanic Approved,Fresh Drop" },
    { "type": "text", "id": "view_all_label", "label": "View-all label", "default": "View all products" },
    { "type": "url", "id": "view_all_link", "label": "View-all link" }
  ],
  "presets": [ { "name": "BG Featured products" } ]
}
{% endschema %}
