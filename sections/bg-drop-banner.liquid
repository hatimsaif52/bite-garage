{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
<div class="bg-wrap">
  <section class="bg-drop" id="drop">
    <div class="bg-drop__inner">
      <div style="max-width:680px;">
        {%- if section.settings.badge != blank -%}<div class="bg-drop__badge">{{ section.settings.badge }}</div>{%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a class="bg-btn bg-btn--dark" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }} &rarr;</a>
      {%- endif -%}
    </div>
  </section>
</div>
{% schema %}
{
  "name": "BG Drop banner",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "★ Incoming drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New designs rolling out of the garage soon." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "View Latest Drop" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [ { "name": "BG Drop banner" } ]
}
{% endschema %}
