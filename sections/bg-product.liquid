{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
{%- assign cv = product.selected_or_first_available_variant -%}
{%- comment -%} Per-product content: metafields first, section settings as fallback {%- endcomment -%}
{%- assign mf = product.metafields.custom -%}
{%- assign pdp_eyebrow    = mf.eyebrow.value    | default: section.settings.subtype -%}
{%- assign pdp_reviews    = mf.reviews.value    | default: section.settings.reviews -%}
{%- assign pdp_badge      = mf.badge.value      | default: section.settings.badge -%}
{%- assign pdp_stamp      = mf.stamp.value      | default: section.settings.stamp -%}
{%- assign pdp_sizechart  = mf.size_chart_url.value | default: section.settings.size_chart_url -%}
{%- assign pdp_accordions = mf.accordions.value -%}
{%- assign pdp_perks      = mf.perks.value -%}
<div class="bg-wrap" id="bg-pdp-{{ section.id }}">
  <div class="bg-section bg-pdp">

    {%- if section.settings.show_breadcrumb -%}
    <nav class="bg-crumb">
      <a href="{{ routes.root_url }}">Home</a> &nbsp;/&nbsp;
      {%- if product.collections.size > 0 -%}
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">Shop</a>
      {%- endif -%}
      &nbsp;/&nbsp; <span>{{ product.title }}</span>
    </nav>
    {%- endif -%}

    <div class="bg-pdp__grid">

      <!-- GALLERY -->
      <div class="bg-gallery">
        <div class="bg-gallery__main">
          {%- if pdp_badge != blank -%}<span class="bg-pdp__badge">{{ pdp_badge }}</span>{%- endif -%}
          {%- if pdp_stamp != blank -%}<span class="bg-pdp__stamp">{{ pdp_stamp }}</span>{%- endif -%}
          {%- if product.featured_media -%}
            <img id="bg-main-img" src="{{ product.featured_media | image_url: width: 1000 }}" alt="{{ product.title | escape }}">
          {%- else -%}
            <span class="bg-slot">&#9634; Main product shot</span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
        <div class="bg-thumbs">
          {%- for media in product.media limit: 8 -%}
            <button type="button" class="bg-thumb{% if forloop.first %} is-active{% endif %}" data-thumb data-src="{{ media | image_url: width: 1000 }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ media | image_url: width: 240 }}" alt="{{ product.title | escape }} {{ forloop.index }}" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
        {%- endif -%}
      </div>

      <!-- BUY BOX -->
      <div class="bg-buy">
        <div class="bg-buy__eyebrow">{{ product.type | default: 'Merch' }}{% if pdp_eyebrow != blank %} &middot; {{ pdp_eyebrow }}{% endif %}</div>
        <h1 class="bg-buy__title">{{ product.title }}</h1>

        <div class="bg-buy__pricerow">
          <span class="bg-buy__price" data-price>{{ cv.price | money }}</span>
          {%- if cv.compare_at_price > cv.price -%}
            <span class="bg-buy__was" data-compare>{{ cv.compare_at_price | money }}</span>
          {%- else -%}
            <span class="bg-buy__was" data-compare hidden></span>
          {%- endif -%}
          {%- if pdp_reviews != blank -%}
            <span class="bg-buy__reviews">&#9733;&#9733;&#9733;&#9733;&#9733; <em>{{ pdp_reviews }}</em></span>
          {%- endif -%}
        </div>

        {%- if product.description != blank -%}
          <div class="bg-buy__desc">{{ product.description | strip_html | truncatewords: 44 }}</div>
        {%- endif -%}

        {%- form 'product', product, id: 'bg-product-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ cv.id }}" data-variant-id>

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              {%- assign dn = option.name | downcase -%}
              {%- assign is_color = false -%}
              {%- assign is_size = false -%}
              {%- if dn contains 'color' or dn contains 'colour' -%}{%- assign is_color = true -%}{%- endif -%}
              {%- if dn contains 'size' -%}{%- assign is_size = true -%}{%- endif -%}
              <div class="bg-opt" data-option-position="{{ option.position }}">
                {%- if is_size and pdp_sizechart != blank -%}
                  <div class="bg-opt__labelrow">
                    <div class="bg-opt__label">{{ option.name }}</div>
                    <a class="bg-sizechart" href="{{ pdp_sizechart }}">Size chart &#9656;</a>
                  </div>
                {%- else -%}
                  <div class="bg-opt__label">{{ option.name }}{% if is_color %} &mdash; <span data-color-name>{{ option.selected_value }}</span>{% endif %}</div>
                {%- endif -%}
                <div class="bg-opt__vals{% if is_color %} bg-opt__vals--color{% endif %}">
                  {%- for value in option.values -%}
                    {%- assign checked = false -%}
                    {%- if option.selected_value == value -%}{%- assign checked = true -%}{%- endif -%}
                    {%- if is_color -%}
                      {%- assign sw = value.swatch.color | default: '' -%}
                      <label class="bg-swatch{% if checked %} is-active{% endif %}" title="{{ value | escape }}"{% if sw != blank %} style="--sw:{{ sw }}"{% endif %}>
                        <input type="radio" name="option{{ option.position }}" value="{{ value | escape }}"{% if checked %} checked{% endif %} data-opt data-sw-name="{{ value | downcase | strip | escape }}" hidden>
                        <span class="bg-swatch__dot"></span>
                      </label>
                    {%- else -%}
                      <label class="bg-pill{% if checked %} is-active{% endif %}">
                        <input type="radio" name="option{{ option.position }}" value="{{ value | escape }}"{% if checked %} checked{% endif %} data-opt hidden>
                        <span>{{ value }}</span>
                      </label>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <div class="bg-buy__actions">
            <div class="bg-qty">
              <button type="button" class="bg-qty__btn" data-qty-dec aria-label="Decrease quantity">&ndash;</button>
              <input class="bg-qty__val" type="number" name="quantity" value="1" min="1" data-qty aria-label="Quantity">
              <button type="button" class="bg-qty__btn" data-qty-inc aria-label="Increase quantity">+</button>
            </div>
            <button type="submit" name="add" class="bg-addcart" data-add{% unless cv.available %} disabled{% endunless %}>
              <span data-add-label>{% if cv.available %}{{ section.settings.add_label }}{% else %}Sold out{% endif %}</span>
            </button>
          </div>
        {%- endform -%}

        {%- if section.settings.show_buy_now and additional_checkout_buttons -%}
          <a href="{{ routes.cart_url }}" class="bg-buynow">Buy it now</a>
        {%- elsif section.settings.buy_now_link != blank -%}
          <a href="{{ section.settings.buy_now_link }}" class="bg-buynow">Buy it now</a>
        {%- endif -%}

        {%- comment -%} Perks: per-product metaobject list first, section blocks as fallback {%- endcomment -%}
        {%- if pdp_perks != blank and pdp_perks.size > 0 -%}
        <div class="bg-perks">
          {%- for entry in pdp_perks -%}
            <div class="bg-perk">
              <div class="bg-perk__icon">{{ entry.icon }}</div>
              <div class="bg-perk__label">{{ entry.label }}</div>
            </div>
          {%- endfor -%}
        </div>
        {%- else -%}
          {%- assign perks = section.blocks | where: 'type', 'perk' -%}
          {%- if perks.size > 0 -%}
          <div class="bg-perks">
            {%- for block in perks -%}
              <div class="bg-perk" {{ block.shopify_attributes }}>
                <div class="bg-perk__icon">{{ block.settings.icon }}</div>
                <div class="bg-perk__label">{{ block.settings.label }}</div>
              </div>
            {%- endfor -%}
          </div>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Accordions: per-product metaobject list first, section blocks as fallback {%- endcomment -%}
        {%- if pdp_accordions != blank and pdp_accordions.size > 0 -%}
        <div class="bg-acc">
          {%- for entry in pdp_accordions -%}
            <details class="bg-acc__item"{% if forloop.first %} open{% endif %}>
              <summary class="bg-acc__head">{{ entry.title }}<span class="bg-acc__sign"></span></summary>
              <div class="bg-acc__body">{{ entry.body }}</div>
            </details>
          {%- endfor -%}
        </div>
        {%- else -%}
          {%- assign accs = section.blocks | where: 'type', 'accordion' -%}
          {%- if accs.size > 0 -%}
          <div class="bg-acc">
            {%- for block in accs -%}
              <details class="bg-acc__item"{% if block.settings.open %} open{% endif %} {{ block.shopify_attributes }}>
                <summary class="bg-acc__head">{{ block.settings.title }}<span class="bg-acc__sign"></span></summary>
                <div class="bg-acc__body">{{ block.settings.body }}</div>
              </details>
            {%- endfor -%}
          </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
(function(){
  var root = document.getElementById('bg-pdp-{{ section.id }}');
  if(!root) return;
  var variants = {{ product.variants | json }};

  var swatchMap = {
    "garage cream":"#F4E8CE","cream":"#F4E8CE","natural":"#F4E8CE",
    "cobalt blue":"#2350C8","cobalt":"#2350C8","blue":"#2350C8","royal":"#2350C8",
    "flo blue":"#3f74c9","sky":"#7db4e6",
    "shop black":"#181410","black":"#181410","ink":"#181410",
    "hazard yellow":"#F4B52A","yellow":"#F4B52A","gold":"#F4B52A","butter":"#f2e0a4",
    "white":"#ffffff","red":"#c0392b","green":"#2e7d32","navy":"#1a2a52",
    "brick":"#9c4a37","berry":"#7c3a54","watermelon":"#e15b62","violet":"#8a7bc4",
    "grey":"#8a8a8a","gray":"#8a8a8a","heather grey":"#9a978f","sand":"#d8c9a3"
  };

  // color option value -> that color's variant image (first variant with an image for the color)
  var colorImage = {};
  variants.forEach(function(v){
    var img = v.featured_image && v.featured_image.src;
    if(!img) return;
    v.options.forEach(function(o){
      var k = String(o).toLowerCase().trim();
      if(!colorImage[k]) colorImage[k] = img;
    });
  });

  // paint swatch dots that have no Shopify swatch color
  root.querySelectorAll('.bg-swatch').forEach(function(l){
    if(l.style.getPropertyValue('--sw')) return;
    var el = l.querySelector('[data-sw-name]');
    var name = el && el.dataset.swName;
    if(name && swatchMap[name]) l.style.setProperty('--sw', swatchMap[name]);
  });

  var idInput   = root.querySelector('[data-variant-id]');
  var priceEl   = root.querySelector('[data-price]');
  var compareEl = root.querySelector('[data-compare]');
  var addBtn    = root.querySelector('[data-add]');
  var addLabel  = root.querySelector('[data-add-label]');
  var soldLabel = 'Sold out';
  var addText   = {{ section.settings.add_label | json }};

  function money(cents){
    var fmt = {{ shop.money_format | json }};
    var amt = (cents/100).toFixed(2).replace(/\.00$/,'');
    return fmt.replace(/\{\{\s*amount(_no_decimals)?\s*\}\}/, amt).replace(/<[^>]+>/g,'') || ('$'+amt);
  }

  function selectedOptions(){
    var opts=[];
    root.querySelectorAll('.bg-opt').forEach(function(g){
      var c=g.querySelector('[data-opt]:checked');
      if(c) opts.push(c.value);
    });
    return opts;
  }

  function findVariant(sel){
    return variants.find(function(v){
      return v.options.length===sel.length && v.options.every(function(o,i){return o===sel[i];});
    });
  }

  function update(){
    var sel=selectedOptions();
    var v = sel.length ? findVariant(sel) : variants[0];
    // refresh active classes
    root.querySelectorAll('[data-opt]').forEach(function(inp){
      var wrap=inp.closest('.bg-swatch,.bg-pill');
      if(wrap) wrap.classList.toggle('is-active', inp.checked);
    });
    var cn=root.querySelector('[data-color-name]');
    if(cn){
      var colorInput=root.querySelector('.bg-opt__vals--color [data-opt]:checked');
      if(colorInput) cn.textContent=colorInput.value;
    }
    if(!v){
      addBtn.disabled=true; addLabel.textContent='Unavailable'; return;
    }
    idInput.value=v.id;
    if(priceEl) priceEl.textContent=money(v.price);
    if(compareEl){
      if(v.compare_at_price && v.compare_at_price>v.price){ compareEl.textContent=money(v.compare_at_price); compareEl.hidden=false; }
      else compareEl.hidden=true;
    }
    // swap gallery to the selected color's image
    var colorInput = root.querySelector('.bg-opt__vals--color [data-opt]:checked');
    var swapSrc = (v.featured_image && v.featured_image.src)
                || (colorInput && colorImage[colorInput.value.toLowerCase().trim()]);
    if(mainImg && swapSrc){
      mainImg.src = swapSrc;
      var base = swapSrc.split('?')[0];
      root.querySelectorAll('[data-thumb]').forEach(function(b){
        b.classList.toggle('is-active', b.dataset.src && b.dataset.src.split('?')[0] === base);
      });
    }
    addBtn.disabled=!v.available;
    addLabel.textContent=v.available?addText:soldLabel;
  }

  root.querySelectorAll('[data-opt]').forEach(function(inp){ inp.addEventListener('change', update); });

  // quantity
  var qty=root.querySelector('[data-qty]');
  root.querySelector('[data-qty-dec]').addEventListener('click',function(){ qty.value=Math.max(1,(parseInt(qty.value,10)||1)-1); });
  root.querySelector('[data-qty-inc]').addEventListener('click',function(){ qty.value=(parseInt(qty.value,10)||1)+1; });

  // gallery thumbs
  var mainImg=root.querySelector('#bg-main-img');
  root.querySelectorAll('[data-thumb]').forEach(function(btn){
    btn.addEventListener('click',function(){
      if(mainImg) mainImg.src=btn.dataset.src;
      root.querySelectorAll('[data-thumb]').forEach(function(b){b.classList.remove('is-active');});
      btn.classList.add('is-active');
    });
  });

  update();
})();
</script>

{% schema %}
{
  "name": "BG Product",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Eyebrow, reviews, badge, stamp, size-chart and accordions are read from product metafields first (see INSTALL.md). The values below are fallbacks used when a product has no metafield set." },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "Show breadcrumb", "default": true },
    { "type": "text", "id": "badge", "label": "Fallback corner badge (top-left)", "default": "Mechanic Approved" },
    { "type": "textarea", "id": "stamp", "label": "Fallback round stamp (bottom-right)", "default": "Certified Fresh" },
    { "type": "text", "id": "subtype", "label": "Fallback eyebrow suffix (after product type)", "default": "Unisex Heavyweight" },
    { "type": "text", "id": "reviews", "label": "Fallback review text (blank to hide)", "default": "(126 reviews)" },
    { "type": "url", "id": "size_chart_url", "label": "Fallback size-chart link" },
    { "type": "text", "id": "add_label", "label": "Add-to-cart label", "default": "Add to cart" },
    { "type": "checkbox", "id": "show_buy_now", "label": "Show dynamic Buy-it-now button", "default": true },
    { "type": "url", "id": "buy_now_link", "label": "Fallback Buy-it-now link (if dynamic checkout off)" }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Trust perk",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon / glyph", "default": "\u2726" },
        { "type": "text", "id": "label", "label": "Label", "default": "Printed to order" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Details & Fit" },
        { "type": "richtext", "id": "body", "label": "Content", "default": "<p>Unisex heavyweight 240gsm cotton with a relaxed garage fit, printed with durable wash-fast inks.</p>" },
        { "type": "checkbox", "id": "open", "label": "Open by default", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "BG Product",
      "blocks": [
        { "type": "perk", "settings": { "icon": "\u2726", "label": "Printed to order" } },
        { "type": "perk", "settings": { "icon": "\u21bb", "label": "Easy returns" } },
        { "type": "perk", "settings": { "icon": "\u2708", "label": "Ships worldwide" } },
        { "type": "accordion", "settings": { "title": "Details & Fit", "open": true, "body": "<p>Unisex heavyweight 240gsm cotton with a relaxed garage fit. The official Bite Garage chest badge is printed using durable, wash-fast inks. Model is 6'1\" wearing size L.</p>" } },
        { "type": "accordion", "settings": { "title": "Materials & Care", "body": "<p>100% combed ring-spun cotton (heather colors contain polyester). Machine wash cold inside-out, hang dry, do not iron directly over the print.</p>" } },
        { "type": "accordion", "settings": { "title": "Shipping & Returns", "body": "<p>Each item is printed to order by Gelato and ships within 24\u201372 hours. Worldwide delivery in 4\u20139 business days. Easy 30-day returns on unworn gear.</p>" } }
      ]
    }
  ]
}
{% endschema %}
