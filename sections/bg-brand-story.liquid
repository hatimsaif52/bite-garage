{{ 'bg-theme.css' | asset_url | stylesheet_tag }}
<div class="bg-wrap">
  <section class="bg-section" id="story" style="padding-top:80px;padding-bottom:80px;">
    <div class="bg-story__card">
      <div class="bg-story__badge">
        <div class="bg-coin">
          <div>
            <small>{{ section.settings.coin_top }}</small>
            <b>{{ section.settings.coin_line1 }}<br>{{ section.settings.coin_line2 }}</b>
            <small>{{ section.settings.coin_bottom }}</small>
          </div>
        </div>
        <span class="bg-bolt" style="top:18px;left:18px;"></span>
        <span class="bg-bolt" style="bottom:18px;right:18px;"></span>
      </div>
      <div class="bg-story__body">
        <div class="bg-kicker" style="color:#F4B52A;">{{ section.settings.kicker }}</div>
        <h2 class="bg-h2" style="font-size:clamp(30px,3.6vw,46px);margin-bottom:20px;">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.body1 }}</p>
        <p>{{ section.settings.body2 }}</p>
        <div class="bg-chips">
          {%- for block in section.blocks -%}
            <div class="bg-chip" {{ block.shopify_attributes }}><i>&#10022;</i> {{ block.settings.text }}</div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>
</div>
{% schema %}
{
  "name": "BG Brand story",
  "settings": [
    { "type": "text", "id": "coin_top", "label": "Coin top text", "default": "★ Official ★" },
    { "type": "text", "id": "coin_line1", "label": "Coin line 1", "default": "Bite" },
    { "type": "text", "id": "coin_line2", "label": "Coin line 2", "default": "Garage" },
    { "type": "text", "id": "coin_bottom", "label": "Coin bottom text", "default": "Workshop Co." },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "// From the garage" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built by a bite mechanic, for bite mechanics." },
    { "type": "textarea", "id": "body1", "label": "Paragraph 1", "default": "Bite Garage is a playful merch brand built around bold characters, mechanic-style graphics, and bite-inspired humor. Every design rolls straight off Dan's workbench and gets printed fresh to order." },
    { "type": "textarea", "id": "body2", "label": "Paragraph 2", "default": "No corporate gloss, no boring basics — just collectible gear stamped with garage-grade personality." }
  ],
  "blocks": [
    { "type": "chip", "name": "Chip", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Designed by Dan" } ] }
  ],
  "max_blocks": 4,
  "presets": [ { "name": "BG Brand story", "blocks": [ {"type":"chip"}, {"type":"chip"}, {"type":"chip"} ] } ]
}
{% endschema %}
